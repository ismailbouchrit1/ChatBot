# === API Intelligence Artificielle ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Base de donnees ===
DATABASE_URL=sqlite:///chatbot.db

# === URL application ===
APP_BASE_URL=http://127.0.0.1:5000
ALLOWED_ORIGINS=

# === Securite applicative ===
SECRET_KEY=change_this_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# === Service d'envoi d'emails (alertes) - Optionnel ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# === Configuration des alertes ===
ALERT_RECIPIENT_DEFAULT=direction@school.ma
ALERT_RECIPIENT_CRITIQUE=
ALERT_RECIPIENT_ELEVEE=
ALERT_RECIPIENT_MODEREE=

# === Environnement ===
FLASK_ENV=development
LOG_LEVEL=DEBUG
DATA_RETENTION_DAYS=365

# === Chiffrement des messages ===
ENCRYPTION_KEY=change_this_to_a_random_32_byte_base64_key

# === CSRF ===
CSRF_SECRET=change_this_to_random_token
